rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.uid is string &&
             data.email is string;
    }

    function isValidNegotiation(data) {
      return data.keys().hasAll(['crop_name', 'quantity', 'location', 'ai_response', 'createdAt']) &&
             data.crop_name is string && data.crop_name.size() <= 100 &&
             data.quantity is string && data.quantity.size() <= 100 &&
             data.location is string && data.location.size() <= 200 &&
             data.ai_response is map &&
             data.ai_response.fair_price is string &&
             data.ai_response.suggested_price_range is string &&
             data.ai_response.negotiation_tips is list &&
             data.ai_response.negotiation_tips.size() <= 10 &&
             data.createdAt == request.time;
    }

    // Collections
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      // Updates are not explicitly needed for this MVP but could be allowed for displayName
      
      match /negotiations/{negotiationId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidNegotiation(request.resource.data);
        allow update, delete: if false; // Negotiations are records of history
      }
    }
  }
}
